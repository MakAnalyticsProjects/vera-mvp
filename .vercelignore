# Massive raw RoofLink export — only needed locally for `pnpm preprocess`.
# The slim apps/web/data/generated.json (~150 KB) is committed and used at
# build time on Vercel.
data/jobs_dedup.jsonl
data/generated.json

# Build outputs
node_modules
.next
.turbo
dist
out

# Tests + dev artifacts
tests/e2e/audit-screens
playwright-report
test-results
coverage

# Production secrets recovery copy — never upload. See CLAUDE.md
# "Production environment" for the policy. The runtime reads its env
# from Vercel's runtime, not from this file.
.env.prod

# Misc
.DS_Store
*.log
.vercel
# Claude Code agent workdir — keeps the manual `vercel --prod` upload from
# trying to ship a worktree's copy of data/jobs_dedup.jsonl (would blow
# past Vercel's 100 MB upload limit).
.claude
# Git worktrees carry their own copies of the gitignored 196 MB JSONL.
# Same failure mode as .claude above — exclude from upload.
worktrees
